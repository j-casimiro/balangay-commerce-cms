# ---------------------------------------------------------------------------
# Root environment template. Copy to `.env` for local development:
#   cp .env.example .env
# docker-compose.yml reads POSTGRES_* from this file for the local database.
# ---------------------------------------------------------------------------

# PostgreSQL container credentials (consumed by docker-compose)
POSTGRES_USER=cms
POSTGRES_PASSWORD=cms_password
POSTGRES_DB=ecommerce_cms

# Prisma / application database connection string
DATABASE_URL=postgresql://cms:cms_password@localhost:5432/ecommerce_cms?schema=public

# Admin API (NestJS)
ADMIN_API_PORT=4000
# Comma-separated list of allowed CORS origins for the API
CORS_ORIGIN=http://localhost:3000

# Storefront (Next.js) — base URL of the admin API
NEXT_PUBLIC_API_URL=http://localhost:4000
