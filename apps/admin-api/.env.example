# Admin API environment template. Copy to `.env` for local development.
DATABASE_URL=postgresql://cms:cms_password@localhost:5432/ecommerce_cms?schema=public
ADMIN_API_PORT=4000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# --- Platform foundations (all optional; sensible defaults shown) ---
# pino log level: trace|debug|info|warn|error|fatal|silent
LOG_LEVEL=debug
# Rate limiting for mutating routes (window in ms + max requests per window)
THROTTLE_TTL=60000
THROTTLE_LIMIT=20
